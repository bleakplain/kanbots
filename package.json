{
  "name": "kanbots",
  "version": "0.0.0",
  "private": true,
  "description": "Local collaboration interface for working on GitHub Issues with Claude Code agents",
  "license": "MIT",
  "author": "leo_cunha87@hotmail.com",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
