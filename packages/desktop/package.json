{
  "name": "@kanbots/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "kanbots desktop app (Electron)",
  "main": "./dist/main.cjs",
  "scripts": {
    "build:main": "tsup",
    "build:web": "pnpm --filter @kanbots/web build",
    "copy:web": "node scripts/copy-web.cjs",
    "build": "pnpm build:web && pnpm build:main && pnpm copy:web",
    "dev": "concurrently -k -n web,electron -c blue,magenta \"pnpm --filter @kanbots/web dev\" \"wait-on http://127.0.0.1:5173 && tsup && KANBOTS_RENDERER_URL=http://127.0.0.1:5173 electron ./dist/main.cjs\"",
    "launch": "pnpm build && electron ./dist/main.cjs",
    "package": "pnpm build && electron-builder --linux AppImage",
    "package:dir": "pnpm build && electron-builder --dir",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/core": "^6.1.6",
    "@octokit/plugin-paginate-rest": "^11.6.0",
    "@octokit/request-error": "^6.1.8",
    "better-sqlite3": "^12.4.1",
    "express": "^5.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@kanbots/api": "workspace:*",
    "@kanbots/core": "workspace:*",
    "@kanbots/dispatcher": "workspace:*",
    "@kanbots/local-store": "workspace:*",
    "@kanbots/web": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "io.kanbots.desktop",
    "productName": "kanbots",
    "executableName": "kanbots",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/file-uri-to-path/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist/**/*", "package.json"],
    "linux": {
      "target": ["AppImage", "tar.xz"],
      "category": "Development",
      "artifactName": "kanbots-${version}.${ext}"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  }
}
