{
  "name": "@kanbots/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kanbots": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kanbots/api": "workspace:*",
    "@kanbots/core": "workspace:*",
    "@kanbots/local-store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
