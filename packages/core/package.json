    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/core": "^6.1.6",
    "@octokit/plugin-paginate-rest": "^11.6.0",
    "@octokit/request-error": "^6.1.8"
  },
  "devDependencies": {
    "@kanbots/local-store": "workspace:*",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
